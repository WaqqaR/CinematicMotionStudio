# Contact form email (Resend) — copy this file to .env.local and fill in.
#
# 1. Create a free account at https://resend.com
# 2. API Keys -> Create API Key -> paste into RESEND_API_KEY below.
# 3. Resend starts in SANDBOX mode: it can only deliver to the email that
#    owns the Resend account, and only from onboarding@resend.dev. While in
#    sandbox, set CONTACT_TO to that owner address so the form works.
# 4. PRODUCTION: verify a domain you own (cyberninjascorp.com or
#    aureliadigital.co.uk) at resend.com/domains, set RESEND_FROM to an
#    address on it (e.g. "AURELIA <hello@aureliadigital.co.uk>"), and CLEAR
#    CONTACT_TO — enquiries then go to site.contactEmail
#    (waqqar@cyberninjascorp.com) and can reach any recipient.
#
# .env.local is gitignored — secrets are never committed.

RESEND_API_KEY=
RESEND_FROM="AURELIA <onboarding@resend.dev>"
# Optional sandbox override for the destination. Leave blank in production.
CONTACT_TO=
