# Contact form email (Resend) — copy this file to .env.local and fill in.
#
# 1. Create a free account at https://resend.com  (sign up with
#    waqqar@cyberninjascorp.com so test sends reach that inbox).
# 2. API Keys -> Create API Key -> paste it below.
# 3. Until you verify a sending domain in Resend, leave RESEND_FROM as the
#    onboarding sender. In test mode Resend only delivers to the address you
#    signed up with — which is the destination, so it works end to end.
# 4. To send from an on-brand address later, verify a domain you own
#    (cyberninjascorp.com or aureliadigital.co.uk) in Resend, then set
#    RESEND_FROM to e.g. "AURELIA <hello@aureliadigital.co.uk>".
#
# .env.local is gitignored — the key is never committed.

RESEND_API_KEY=
RESEND_FROM="AURELIA <onboarding@resend.dev>"
